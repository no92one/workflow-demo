root = true

[*.cs]

dotnet_diagnostic.IDE1006.severity = warning

dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false
csharp_new_line_before_open_brace = all

dotnet_naming_style.pascal_case_style.capitalization = pascal_case
dotnet_naming_style.interface_style.capitalization = pascal_case
dotnet_naming_style.interface_style.required_prefix = I

dotnet_naming_symbols.class_symbols.applicable_kinds = class
dotnet_naming_symbols.class_symbols.applicable_accessibilities = *

dotnet_naming_symbols.interface_symbols.applicable_kinds = interface
dotnet_naming_symbols.interface_symbols.applicable_accessibilities = *

dotnet_naming_rule.classes_must_be_pascal_case.symbols = class_symbols
dotnet_naming_rule.classes_must_be_pascal_case.style = pascal_case_style
dotnet_naming_rule.classes_must_be_pascal_case.severity = warning

dotnet_naming_rule.interfaces_must_be_i_pascal_case.symbols = interface_symbols
dotnet_naming_rule.interfaces_must_be_i_pascal_case.style = interface_style
dotnet_naming_rule.interfaces_must_be_i_pascal_case.severity = warning